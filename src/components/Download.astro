    label: 'Download for Linux',
    sub: 'x86_64 · .AppImage / .deb',
    primary: false,
  },
  {
    name: 'Windows',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>`,
    label: 'Download for Windows',
    sub: 'x86_64 · .exe installer',
    primary: false,
  },
