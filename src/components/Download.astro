---

<section id="download" class="py-24 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="text-xs font-mono text-accent-green uppercase tracking-widest mb-4">Free · Proprietary</div>
    <h2 class="text-4xl md:text-5xl font-bold mb-4">
      Start trading smarter
    </h2>
    <p class="text-text-secondary text-lg mb-12 max-w-2xl mx-auto">
      MarketMaker Scalper is free to download and use. Available for all major platforms.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
      {platforms.map((p) => (
        <a
          href="#"
          class={`flex items-center gap-4 px-6 py-4 rounded-2xl border transition-all duration-200 group
            ${p.primary
              ? 'bg-accent-green text-bg-primary border-accent-green hover:bg-accent-green-dim hover:scale-105'
              : 'bg-bg-card border-border text-text-primary hover:border-border-light hover:bg-bg-hover'
            }`}
        >
          <div class={p.primary ? 'text-bg-primary' : 'text-text-secondary'} set:html={p.icon} />
          <div class="text-left">
            <div class={`font-semibold text-sm ${p.primary ? 'text-bg-primary' : 'text-text-primary'}`}>{p.label}</div>
            <div class={`text-xs ${p.primary ? 'text-bg-primary/70' : 'text-text-muted'}`}>{p.sub}</div>
          </div>
        </a>
      ))}
    </div>

    <div class="flex items-center justify-center gap-3">
      <span class="text-text-muted text-sm font-mono">Free to use · Proprietary software</span>
    </div>

    <!-- Mock version badge -->
    <div class="mt-8 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border bg-bg-card text-text-muted text-xs font-mono">
      <span class="w-1.5 h-1.5 rounded-full bg-accent-green"></span>
      Latest release: v0.1.0
    </div>
  </div>
</section>
