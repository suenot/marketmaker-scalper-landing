---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h18v18H3z" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>`,
    title: 'Real-time Order Books',
    description: 'Visualize market depth with live order book updates. Color-coded bid/ask heatmaps reveal hidden liquidity and market pressure at a glance.',
    color: 'green',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
    title: 'Advanced Charting',
    description: 'Candlestick, tick, cluster, and bubble charts with customizable timeframes. Analyze price action the way professionals do.',
    color: 'blue',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>`,
    title: 'Hotkey Trading',
    description: 'Execute orders in milliseconds with F1–F5 hotkeys. Buy market, sell market, close positions, cancel all — without touching the mouse.',
    color: 'yellow',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    title: 'Multi-Dashboard Layout',
    description: 'Create unlimited dashboards with drag-and-drop pane grids. Split, resize, and organize widgets to match your trading workflow.',
    color: 'purple',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Encrypted Credentials',
    description: 'API keys are encrypted with a master password and stored locally. Your credentials never leave your machine.',
    color: 'red',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Multi-Account Support',
    description: 'Manage multiple exchange accounts simultaneously. Organize trades into groups and monitor all portfolios from a single view.',
    color: 'cyan',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: 'Built with Rust',
    description: 'Native performance with zero garbage collection pauses. The Iced GUI framework ensures smooth 60fps rendering even under heavy data load.',
    color: 'orange',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: 'gRPC Data Streaming',
    description: 'Real-time market data via gRPC with automatic reconnection. Plug in custom data providers or use built-in exchange connectors.',
    color: 'green',
  },
];

const colorMap: Record<string, string> = {
  green: 'text-accent-green bg-accent-green/10 border-accent-green/20',
  blue: 'text-accent-blue bg-accent-blue/10 border-accent-blue/20',
  yellow: 'text-accent-yellow bg-accent-yellow/10 border-accent-yellow/20',
  purple: 'text-accent-purple bg-accent-purple/10 border-accent-purple/20',
  red: 'text-accent-red bg-accent-red/10 border-accent-red/20',
  cyan: 'text-accent-cyan bg-accent-cyan/10 border-accent-cyan/20',
  orange: 'text-accent-orange bg-accent-orange/10 border-accent-orange/20',
};
---

<section id="features" class="py-24 px-6 max-w-7xl mx-auto">
  <div class="text-center mb-16">
    <div class="text-xs font-mono text-accent-green uppercase tracking-widest mb-4">Features</div>
    <h2 class="text-4xl md:text-5xl font-bold mb-4">
      Everything a <span class="text-accent-green">professional</span> needs
    </h2>
    <p class="text-text-secondary max-w-2xl mx-auto text-lg">
      Built from the ground up for scalpers and professional traders who demand speed, precision, and control.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
    {features.map((feature) => (
      <div class="group p-6 rounded-2xl border border-border bg-bg-card hover:bg-bg-hover hover:border-border-light transition-all duration-300 bg-card-gradient">
        <div class={`w-12 h-12 rounded-xl border flex items-center justify-center mb-4 ${colorMap[feature.color]}`} set:html={feature.icon} />
        <h3 class="font-semibold text-text-primary mb-2 text-base">{feature.title}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
      </div>
    ))}
  </div>
</section>
