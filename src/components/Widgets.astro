---
const widgetGroups = [
  {
    title: 'Market Data',
    color: 'accent-green',
    widgets: [
      { name: 'Order Book', desc: 'Real-time bid/ask depth with heatmap visualization' },
      { name: 'Live Trades', desc: 'Filtered trade feed with size aggregation' },
      { name: 'Candlestick Chart', desc: 'OHLCV charts with multiple timeframes' },
      { name: 'Cluster Chart', desc: 'Volume-at-price analysis and market profile' },
      { name: 'Tick Chart', desc: 'Tick-by-tick price movement visualization' },
      { name: 'Bubble Chart', desc: 'Advanced market dynamics visualization' },
    ],
  },
  {
    title: 'Trading',
    color: 'accent-blue',
    widgets: [
      { name: 'Order Form', desc: 'Market, Limit, Stop, Take Profit order types' },
      { name: 'Open Orders', desc: 'Active orders with instant cancel/modify' },
      { name: 'Positions', desc: 'Live P&L tracking across all positions' },
      { name: 'Trade History', desc: 'Complete execution history and stats' },
    ],
  },
  {
    title: 'Portfolio',
    color: 'accent-purple',
    widgets: [
      { name: 'Balance Overview', desc: 'Account balances with pie chart breakdown' },
      { name: 'Portfolio Tracker', desc: 'Holdings and performance over time' },
      { name: 'Deals Manager', desc: 'Create and track trading groups/deals' },
    ],
  },
  {
    title: 'Management',
    color: 'accent-yellow',
    widgets: [
      { name: 'Exchange Browser', desc: 'Browse all supported markets and pairs' },
      { name: 'Account Manager', desc: 'Multi-account API key management' },
      { name: 'Provider Setup', desc: 'Configure data provider connections' },
      { name: 'Market Data', desc: 'Global market overview and stats' },
    ],
  },
];

const colorMap: Record<string, string> = {
  'accent-green': 'text-accent-green border-accent-green/30 bg-accent-green/5',
  'accent-blue': 'text-accent-blue border-accent-blue/30 bg-accent-blue/5',
  'accent-purple': 'text-accent-purple border-accent-purple/30 bg-accent-purple/5',
  'accent-yellow': 'text-accent-yellow border-accent-yellow/30 bg-accent-yellow/5',
};
---

<section id="widgets" class="py-32 px-6 max-w-7xl mx-auto relative">
  <div class="text-center mb-20">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent-purple/30 bg-accent-purple/10 text-[10px] font-mono text-accent-purple uppercase tracking-[0.2em] mb-6">
      Modularity
    </div>
    <h2 class="text-5xl md:text-6xl font-bold mb-6 tracking-tight text-white">
      <span class="text-accent-green">Infinite</span> Composability
    </h2>
    <p class="text-text-secondary max-w-2xl mx-auto text-xl leading-relaxed">
      Build your ultimate workspace with 24+ high-performance widgets. Seamlessly drag and drop to create custom configurations tailored to your strategy.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
    {widgetGroups.map((group) => (
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-br from-white/[0.05] to-transparent rounded-3xl -z-10"></div>
        <div class="p-8 rounded-3xl border border-white/10 bg-bg-card/40 backdrop-blur-sm hover:border-white/20 transition-all shadow-xl h-full">
          <div class={`inline-flex items-center gap-2 px-4 py-1.5 rounded-xl border text-[11px] font-bold font-mono mb-6 shadow-sm ${colorMap[group.color]}`}>
            {group.title.toUpperCase()}
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
            {group.widgets.map((w) => (
              <div class="flex flex-col gap-1 group/item">
                <div class="flex items-center gap-2">
                  <div class="w-1.5 h-1.5 rounded-full bg-accent-green/40 group-hover/item:bg-accent-green transition-colors"></div>
                  <span class="text-text-primary text-base font-semibold tracking-tight">{w.name}</span>
                </div>
                <p class="text-text-muted text-xs leading-relaxed pl-3.5 opacity-60 group-hover/item:opacity-100 transition-opacity">
                  {w.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Layout highlight -->
  <div class="relative p-10 rounded-[2.5rem] border border-accent-green/20 bg-accent-green/5 overflow-hidden group">
    <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
       <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
          <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
       </svg>
    </div>
    <div class="flex flex-col md:flex-row items-center gap-10 relative z-10">
      <div class="w-16 h-16 rounded-2xl bg-accent-green/20 border border-accent-green/30 flex items-center justify-center flex-shrink-0 shadow-[0_0_30px_rgba(0,212,160,0.2)]">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#00d4a0" stroke-width="2">
          <path d="M12 3v18M3 12h18M3 3h18v18H3z" stroke-dasharray="2 2" />
        </svg>
      </div>
      <div>
        <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">Advanced Grid Layout Engine</h3>
        <p class="text-text-secondary text-lg leading-relaxed max-w-3xl">
          Don't let your tools limit your vision. Arrange widgets with pixel-perfect precision using our split-pane system. 
          Save multiple workspace presets and switch between them instantly with global hotkeys.
        </p>
      </div>
    </div>
  </div>
</section>
