---
const hotkeys = [
  { key: 'F1', action: 'Buy Market', desc: 'Instant market buy order', color: 'accent-green' },
  { key: 'F2', action: 'Sell Market', desc: 'Instant market sell order', color: 'accent-red' },
  { key: 'F3', action: 'Close Long', desc: 'Close all long positions', color: 'accent-yellow' },
  { key: 'F4', action: 'Close Short', desc: 'Close all short positions', color: 'accent-yellow' },
  { key: 'F5', action: 'Cancel All', desc: 'Cancel all open orders', color: 'accent-orange' },
  { key: 'Esc', action: 'Emergency Exit', desc: 'Close all positions immediately', color: 'accent-red' },
  { key: 'Space', action: 'Freeze Book', desc: 'Pause order book updates', color: 'accent-blue' },
  { key: 'Ctrl+Z', action: 'Undo Order', desc: 'Cancel last placed order', color: 'accent-purple' },
  { key: 'H', action: 'Toggle Help', desc: 'Show / hide hotkey overlay', color: 'text-secondary' },
  { key: '1–9', action: 'Qty Presets', desc: 'Select preset position sizes', color: 'accent-cyan' },
  { key: '[', action: 'Decrease Size', desc: 'Reduce position size by step', color: 'text-secondary' },
  { key: ']', action: 'Increase Size', desc: 'Increase position size by step', color: 'text-secondary' },
];

const colorMap: Record<string, { key: string; badge: string }> = {
  'accent-green': { key: 'border-accent-green/40 bg-accent-green/10 text-accent-green', badge: 'bg-accent-green text-bg-primary' },
  'accent-red': { key: 'border-accent-red/40 bg-accent-red/10 text-accent-red', badge: 'bg-accent-red text-bg-primary' },
  'accent-yellow': { key: 'border-accent-yellow/40 bg-accent-yellow/10 text-accent-yellow', badge: 'bg-accent-yellow text-bg-primary' },
  'accent-orange': { key: 'border-accent-orange/40 bg-accent-orange/10 text-accent-orange', badge: 'bg-accent-orange text-bg-primary' },
  'accent-blue': { key: 'border-accent-blue/40 bg-accent-blue/10 text-accent-blue', badge: 'bg-accent-blue text-bg-primary' },
  'accent-purple': { key: 'border-accent-purple/40 bg-accent-purple/10 text-accent-purple', badge: 'bg-accent-purple text-bg-primary' },
  'accent-cyan': { key: 'border-accent-cyan/40 bg-accent-cyan/10 text-accent-cyan', badge: 'bg-accent-cyan text-bg-primary' },
  'text-secondary': { key: 'border-border bg-bg-hover text-text-secondary', badge: 'bg-bg-hover text-text-secondary border border-border' },
};
---

<section id="hotkeys" class="py-32 px-6 bg-gradient-to-b from-bg-primary to-bg-secondary/50">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-accent-blue/30 bg-accent-blue/10 text-[10px] font-mono text-accent-blue uppercase tracking-[0.2em] mb-6">
        Performance
      </div>
      <h2 class="text-5xl md:text-6xl font-bold mb-6 tracking-tight text-white">
        Trade at the <span class="text-accent-green">Speed of Thought</span>
      </h2>
      <p class="text-text-secondary max-w-2xl mx-auto text-xl leading-relaxed">
        Millisecond precision execution. Our advanced hotkey engine allows you to manage positions and orders without ever touching your mouse.
      </p>
    </div>

    <!-- Hotkey Grid -->
    <div class="max-w-5xl mx-auto">
      <div class="relative p-8 rounded-[2.5rem] bg-[#0e0f17] border border-white/10 shadow-2xl overflow-hidden group">
        <!-- Decoration -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-accent-green/5 blur-[80px] -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent-blue/5 blur-[80px] translate-y-1/2 -translate-x-1/2"></div>

        <div class="relative z-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {hotkeys.map((hk) => (
            <div class="flex items-center gap-4 p-4 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/[0.08] hover:border-white/10 transition-all group/key">
              <div class={`flex items-center justify-center min-w-[56px] h-11 rounded-xl border-b-[3px] border-x border-t font-mono text-sm font-bold shadow-lg transition-transform group-hover/key:-translate-y-0.5 group-active/key:translate-y-0.5 group-active/key:border-b-0 ${colorMap[hk.color]?.key}`}>
                {hk.key}
              </div>
              <div class="overflow-hidden">
                <div class="text-text-primary text-base font-semibold truncate group-hover/key:text-white transition-colors">{hk.action}</div>
                <div class="text-text-muted text-xs truncate opacity-70">{hk.desc}</div>
              </div>
            </div>
          ))}
        </div>

        <!-- Instruction bar -->
        <div class="mt-8 pt-6 border-t border-white/5 flex items-center justify-between text-[11px] font-mono text-[#8695a8]">
           <div class="flex items-center gap-4">
              <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-accent-green"></span> FULLY CUSTOMIZABLE</span>
              <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-accent-blue"></span> LOW LATENCY ENGINE</span>
           </div>
           <div class="hidden sm:block">PRESS <kbd class="px-1.5 py-0.5 rounded bg-white/10 border border-white/10 text-white">H</kbd> FOR HELP OVERLAY</div>
        </div>
      </div>
    </div>

    <!-- Speed highlight (3 icons) -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {[
        { stat: '< 0.5ms', label: 'Average internal latency', icon: '⚡', color: 'text-accent-green bg-accent-green/5 border-accent-green/20' },
        { stat: '60 FPS', label: 'Smooth rendering engine', icon: '🎯', color: 'text-accent-blue bg-accent-blue/5 border-accent-blue/20' },
        { stat: 'NO GC', label: 'Rust memory safety', icon: '🦀', color: 'text-accent-orange bg-accent-orange/5 border-accent-orange/20' },
      ].map((item) => (
        <div class={`relative p-8 rounded-3xl border transition-all hover:scale-[1.05] ${item.color}`}>
          <div class="text-4xl mb-4">{item.icon}</div>
          <div class="text-4xl font-bold font-mono tracking-tighter mb-1">{item.stat}</div>
          <div class="text-text-secondary text-sm font-medium">{item.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
