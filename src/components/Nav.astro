<script is:inline>
(function () {
  var nav = document.getElementById('navbar');
  window.addEventListener('scroll', function () {
    if (window.scrollY > 20) {
      nav.classList.remove('py-4', 'bg-transparent');
      nav.classList.add('py-3', 'bg-[#0a0b0f]/80', 'backdrop-blur-md', 'border-b', 'border-white/5', 'shadow-lg');
    } else {
      nav.classList.add('py-4', 'bg-transparent');
      nav.classList.remove('py-3', 'bg-[#0a0b0f]/80', 'backdrop-blur-md', 'border-b', 'border-white/5', 'shadow-lg');
    }
  }, { passive: true });
})();
</script>
