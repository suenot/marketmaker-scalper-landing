<section class="relative min-h-screen flex flex-col items-center justify-center pt-24 pb-20 px-4 overflow-hidden">
  <!-- Dynamic Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[#0a0b0f]"></div>
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 50% -20%, #00d4a030, transparent 70%);"></div>
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-accent-green/5 blur-[120px] rounded-full animate-pulse-slow"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 text-center max-w-5xl mx-auto mb-16">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-accent-green/20 bg-accent-green/5 mb-8 animate-fade-in">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-green"></span>
      </span>
      <span class="text-xs font-mono font-medium text-accent-green tracking-wide">V0.1.0 • HIGH PERFORMANCE TRADING</span>
    </div>

    <h1 class="text-6xl md:text-8xl font-bold tracking-tighter mb-6 leading-[0.9] text-balance">
      Precision Trading<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-green to-accent-blue">Real-Time Speed</span>
    </h1>

    <p class="text-xl md:text-2xl mb-10 max-w-2xl mx-auto leading-relaxed text-text-secondary">
      Professional crypto scalping terminal built with <span class="text-text-primary font-medium">Rust & Iced</span>.
      Blazing fast execution, advanced cluster charts, and deep liquidity visualization.
    </p>

    <div class="flex flex-col sm:flex-row gap-5 justify-center items-center mb-12">
      <a href="#download"
         class="px-10 py-4 rounded-xl font-bold text-lg transition-all bg-accent-green text-bg-primary hover:shadow-[0_0_20px_rgba(0,212,160,0.4)] hover:scale-105 active:scale-95">
        Get Started Free
      </a>
      <a href="#features"
         class="px-10 py-4 rounded-xl border border-border bg-bg-card/50 backdrop-blur-sm font-medium text-lg transition-all hover:bg-bg-hover hover:border-border-light">
        View Features
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-12 py-4 border-y border-border/50">
      {[
        ['20+','Exchanges'],
        ['<1ms','Latency'],
        ['Rust','Backend'],
        ['0%','Fees']
      ].map(([v,l]) => (
        <div class="flex flex-col items-center">
          <div class="text-4xl font-bold font-mono text-text-primary tracking-tighter whitespace-nowrap">{v}</div>
          <div class="text-xs font-medium text-accent-green/60 uppercase tracking-widest mt-1">{l}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════ TERMINAL SCREENSHOT ═══════════════════════════ -->
  <div class="relative z-10 w-full max-w-[1200px] mx-auto terminal-float px-2 sm:px-0">
    <!-- Glow behind terminal -->
    <div class="absolute -inset-4 bg-accent-green/10 blur-3xl opacity-50 rounded-[2rem]"></div>

    <img
      src="/terminal-demo.png"
      alt="MarketMaker Scalper terminal — real-time cluster chart and order book"
      class="relative w-full h-auto block"
      width="1400"
      height="900"
    />
  </div>

</section>

<style>
  .terminal-float {
    animation: termFloat 8s ease-in-out infinite;
    perspective: 1000px;
  }
  @keyframes termFloat {
    0%, 100% { transform: translateY(0) rotateX(1deg) rotateY(-0.5deg); }
    50% { transform: translateY(-15px) rotateX(-1deg) rotateY(0.5deg); }
  }

  .bg-grid {
    background-image:
      linear-gradient(rgba(0, 212, 160, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 160, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  /* Smooth reveal for typography */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
</style>

