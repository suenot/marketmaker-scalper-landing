---

<section class="relative min-h-screen flex flex-col items-center justify-center pt-20 pb-16 px-4 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0" style="background:radial-gradient(ellipse 80% 50% at 50% -10%,rgba(38,166,154,0.08),transparent),#0a0b0f;"></div>
  <div class="absolute inset-0 opacity-30" style="background-image:linear-gradient(rgba(38,166,154,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(38,166,154,0.04) 1px,transparent 1px);background-size:40px 40px;"></div>

  <!-- Hero text -->
  <div class="relative z-10 text-center max-w-4xl mx-auto mb-10">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border mb-6 text-xs font-mono"
         style="border-color:rgba(38,166,154,0.35);background:rgba(38,166,154,0.06);color:#26a69a;">
      <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:#26a69a;"></span>
      Built with Rust · iced GUI · Open Source · MIT
    </div>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-5 leading-none" style="color:#c0c0cc;">
      Professional<br/>
      <span style="color:#26a69a;">Crypto Scalping</span><br/>
      Terminal
    </h1>
    <p class="text-lg mb-8 max-w-2xl mx-auto leading-relaxed" style="color:#808090;">
      Trade across 20+ exchanges with real-time order books, advanced charting,
      and hotkey-driven execution — all in a single, blazing-fast desktop app.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-10">
      <a href="#download"
         class="px-8 py-3.5 rounded-lg font-bold text-base transition-all hover:opacity-90 hover:scale-105"
         style="background:#26a69a;color:#0f0f1e;">
        Download Free
      </a>
      <a href="#features"
         class="px-8 py-3.5 rounded-lg border font-medium text-base transition-all"
         style="border-color:#333348;color:#808090;">
        Explore Features
      </a>
    </div>
    <div class="flex flex-wrap justify-center gap-10">
      {[['20+','Exchanges'],['24+','Widget Types'],['<1ms','Latency'],['MIT','License']].map(([v,l]) => (
        <div class="text-center">
          <div class="text-3xl font-bold font-mono" style="color:#26a69a;">{v}</div>
          <div class="text-sm mt-1" style="color:#808090;">{l}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       TERMINAL MOCKUP — faithful to source
       ═══════════════════════════════════════ -->
  <div class="relative z-10 w-full max-w-[1280px] mx-auto terminal-float">
    <div class="rounded-xl overflow-hidden border"
         style="border-color:#333348;background:#1a1a2e;box-shadow:0 40px 100px rgba(0,0,0,0.75),0 0 40px rgba(38,166,154,0.05);">

      <!-- ── Tab Bar (36px, #0f0f1e, from tab_bar.rs) ── -->
      <div class="flex items-center justify-between px-2"
           style="height:36px;background:#0f0f1e;border-bottom:1px solid #2a2a3e;">
        <div class="flex items-center gap-1">
          <!-- Active tab: TAB_ACTIVE=#333359, border rgba(255,255,255,0.15) -->
          <div class="flex items-center px-3 rounded select-none"
               style="height:26px;background:#333359;color:#ffffff;border:1px solid rgba(255,255,255,0.15);font-size:11px;font-family:monospace;">
            Dashboard 1
          </div>
          <!-- Inactive tab: TAB_INACTIVE=#1f1f38 -->
          <div class="flex items-center px-3 rounded select-none"
               style="height:26px;background:#1f1f38;color:#808090;font-size:11px;font-family:monospace;">
            Dashboard 2
          </div>
          <div class="flex items-center justify-center rounded ml-1 select-none"
               style="height:26px;width:26px;background:rgba(255,255,255,0.04);color:#808090;font-size:14px;">+</div>
        </div>
        <!-- Right: mps | fps + Settings + User -->
        <div class="flex items-center gap-2" style="font-size:10px;font-family:monospace;">
          <span style="color:#26a69a;">8 mps</span>
          <span style="color:#808090;">|</span>
          <span style="color:#808090;">62 fps</span>
          <span class="px-2 rounded" style="height:22px;line-height:22px;background:rgba(255,255,255,0.04);color:#808090;font-size:10px;">Settings</span>
          <span class="px-2 rounded" style="height:22px;line-height:22px;background:rgba(255,255,255,0.04);color:#808090;font-size:10px;">User</span>
        </div>
      </div>

      <!-- ── Pane Grid: 3 columns ── -->
      <div style="display:grid;grid-template-columns:220px 1fr 210px;height:510px;">

        <!-- ═══ ORDER BOOK (from orderbook/mod.rs) ═══ -->
        <div style="display:flex;flex-direction:column;border-right:1px solid #333348;background:#161628;">
          <!-- Widget header (28px, #0f0f1e, from wrapper.rs) -->
          <div class="flex items-center gap-1.5"
               style="height:28px;flex-shrink:0;background:#0f0f1e;border-bottom:1px solid #2a2a3e;padding:0 6px;">
            <!-- Group color bar (cyan group) -->
            <div style="width:3px;height:16px;background:#33b8c8;border-radius:2px;flex-shrink:0;"></div>
            <span style="font-size:12px;color:#c0c0cc;font-family:sans-serif;">Order Book</span>
            <div style="font-size:9px;color:#808090;background:rgba(255,255,255,0.05);padding:1px 4px;border-radius:2px;margin-left:2px;font-family:monospace;">orderbook</div>
            <div style="flex:1;"></div>
            <span style="background:rgba(255,255,255,0.04);color:#808090;font-size:10px;padding:1px 5px;border-radius:2px;font-family:monospace;">_</span>
            <span style="background:rgba(255,0,0,0.08);color:#ef5350;font-size:10px;padding:1px 5px;border-radius:2px;font-family:monospace;margin-left:2px;">×</span>
          </div>
          <!-- Order Book canvas — SVG replica of orderbook/mod.rs draw() -->
          <div style="flex:1;overflow:hidden;background:#161628;">
            <svg width="100%" height="100%" viewBox="0 0 220 482" preserveAspectRatio="xMidYMid meet" style="display:block;">
              <rect width="220" height="482" fill="#161628"/>

              <!-- ASKS (top) — best ask at bottom of section -->
              {asks.map((row, i) => {
                const y = 4 + i * 28;
                const intensity = row.pct / 100;
                const bgA = 0.06 + intensity * 0.14;
                const barA = 0.3 + intensity * 0.5;
                const barW = intensity * 62;
                return <>
                  <rect x="0" y={y} width="220" height="27" fill={`rgba(239,83,80,${bgA})`}/>
                  {/* Volume bar — RIGHT side of center price col */}
                  <rect x={155} y={y+2} width={barW} height="23" fill={`rgba(239,83,80,${barA})`} rx="1"/>
                  {/* Horizontal grid line */}
                  <line x1="0" y1={y+27} x2="220" y2={y+27} stroke="#2a2a3e" stroke-width="0.5"/>
                  {/* Volume text */}
                  <text x="157" y={y+16} fill="#ffffff" font-size="10" font-family="monospace">{row.vol}</text>
                  {/* Price — centered at x=110 */}
                  <text x="110" y={y+16} fill="#ef5350" font-size="10" font-family="monospace" text-anchor="middle">{row.price}</text>
                </>;
              })}

              <!-- Spread area (dark bg + yellow label + golden last-price line) -->
              <rect x="0" y={4 + asks.length * 28} width="220" height="22" fill="rgba(6,6,20,0.7)"/>
              <line x1="0" y1={4 + asks.length * 28 + 1} x2="220" y2={4 + asks.length * 28 + 1} stroke="#ffd700" stroke-width="1.5"/>
              <text x="110" y={4 + asks.length * 28 + 15} fill="#ffeb3b" font-size="10" font-family="monospace" text-anchor="middle">Spread: 0.50 · 0.0007%</text>

              <!-- BIDS (bottom) — best bid at top -->
              {bids.map((row, i) => {
                const y = 4 + asks.length * 28 + 22 + i * 28;
                const intensity = row.pct / 100;
                const bgA = 0.06 + intensity * 0.14;
                const barA = 0.3 + intensity * 0.5;
                const barW = intensity * 62;
                return <>
                  <rect x="0" y={y} width="220" height="27" fill={`rgba(38,166,154,${bgA})`}/>
                  {/* Volume bar — LEFT side of center (from price col leftward) */}
                  <rect x={110 - 45 - barW} y={y+2} width={barW} height="23" fill={`rgba(38,166,154,${barA})`} rx="1"/>
                  <line x1="0" y1={y+27} x2="220" y2={y+27} stroke="#2a2a3e" stroke-width="0.5"/>
                  {/* Volume text right-aligned before price */}
                  <text x="63" y={y+16} fill="#ffffff" font-size="10" font-family="monospace" text-anchor="end">{row.vol}</text>
                  <text x="110" y={y+16} fill="#26a69a" font-size="10" font-family="monospace" text-anchor="middle">{row.price}</text>
                </>;
              })}

              <!-- Vertical center divider (price axis column) -->
              <line x1="65"  y1="0" x2="65"  y2="482" stroke="#2a2a3e" stroke-width="0.5"/>
              <line x1="155" y1="0" x2="155" y2="482" stroke="#2a2a3e" stroke-width="0.5"/>
            </svg>
          </div>
        </div>

        <!-- ═══ CHART (from chart/mod.rs) ═══ -->
        <div style="display:flex;flex-direction:column;border-right:1px solid #333348;background:#161628;">
          <!-- Widget header -->
          <div class="flex items-center gap-1.5"
               style="height:28px;flex-shrink:0;background:#0f0f1e;border-bottom:1px solid #2a2a3e;padding:0 6px;">
            <div style="width:3px;height:16px;background:#3366cc;border-radius:2px;flex-shrink:0;"></div>
            <span style="font-size:12px;color:#c0c0cc;font-family:sans-serif;">Chart</span>
            <div style="font-size:9px;color:#808090;background:rgba(255,255,255,0.05);padding:1px 4px;border-radius:2px;margin-left:2px;font-family:monospace;">chart</div>
            <div style="flex:1;"></div>
            <!-- Timeframe selector (1m active) -->
            {['1m','5m','15m','1h','4h','1D'].map(tf => (
              <span style={`font-size:9px;font-family:monospace;padding:0 3px;color:${tf==='1m'?'#26a69a':'#808090'};`}>{tf}</span>
            ))}
            <span style="background:rgba(255,255,255,0.04);color:#808090;font-size:10px;padding:1px 5px;border-radius:2px;margin-left:4px;font-family:monospace;">_</span>
            <span style="background:rgba(255,0,0,0.08);color:#ef5350;font-size:10px;padding:1px 5px;border-radius:2px;margin-left:2px;font-family:monospace;">×</span>
          </div>
          <!-- Chart canvas — SVG replica of chart/mod.rs draw() -->
          <div style="flex:1;overflow:hidden;background:#161628;">
            <svg width="100%" height="100%" viewBox="0 0 820 482" preserveAspectRatio="none" style="display:block;">
              <rect width="820" height="482" fill="#161628"/>

              <!-- chart area: x 0..750, y 0..422; volume area: y 422..482; price axis: x 750..820 -->
              <!-- Horizontal grid lines + price labels (6 lines, from chart/mod.rs) -->
              {[0,1,2,3,4,5,6].map(i => {
                const y = Math.round((i / 6) * 422);
                const price = (67535 - (i / 6) * 55).toFixed(1);
                return <>
                  <line x1="0" y1={y} x2="750" y2={y} stroke="#2a2a3e" stroke-width="0.5"/>
                  <text x="818" y={y+4} fill="#808090" font-size="9" font-family="monospace" text-anchor="end">{price}</text>
                </>;
              })}
              <!-- Volume area separator -->
              <line x1="0" y1="422" x2="750" y2="422" stroke="#2a2a3e" stroke-width="0.5"/>
              <!-- Price axis separator -->
              <line x1="750" y1="0" x2="750" y2="482" stroke="#2a2a3e" stroke-width="0.5"/>

              <!-- Candlesticks + volume bars -->
              {candles.map((c, i) => {
                const cw = 750 / candles.length;
                const x = i * cw;
                const cx = x + cw / 2;
                const bw = Math.max(cw * 0.65, 2);

                // price% → Y: 0%=bottom(422), 102%=top(0)
                const pToY = (p: number) => 422 - (p / 102) * 422;

                const openY  = pToY(c[0] as number);
                const closeY = pToY(c[1] as number);
                const highY  = pToY(c[2] as number);
                const lowY   = pToY(c[3] as number);
                const bull   = c[4] as boolean;
                const bodyTop = Math.min(openY, closeY);
                const bodyH  = Math.max(Math.abs(openY - closeY), 2);
                const color  = bull ? '#26a69a' : '#ef5350';

                const vol = Math.abs((c[1] as number) - (c[0] as number)) + 4;
                const volH = Math.max((vol / 25) * 54, 3);
                const volA = 0.3 + (vol / 25) * 0.5;
                const volColor = bull ? `rgba(38,166,154,${volA})` : `rgba(239,83,80,${volA})`;

                return <>
                  {/* Wick (high→low) */}
                  <line x1={cx} y1={highY} x2={cx} y2={lowY} stroke={color} stroke-width="1"/>
                  {/* Body */}
                  <rect x={cx - bw/2} y={bodyTop} width={bw} height={bodyH} fill={color}/>
                  {/* Volume bar */}
                  <rect x={cx - bw/2} y={482 - volH} width={bw} height={volH} fill={volColor}/>
                </>;
              })}

              <!-- Last price golden dashed line (at ~60% of chart height = y≈169) -->
              <line x1="0" y1="169" x2="750" y2="169" stroke="#ffd700" stroke-width="1" stroke-dasharray="4,3"/>
              <!-- Price label box on right axis -->
              <rect x="750" y="162" width="70" height="14" fill="#ffd700"/>
              <text x="818" y="172" fill="#0f0f1e" font-size="9" font-family="monospace" text-anchor="end" font-weight="bold">67,513.0</text>
            </svg>
          </div>
        </div>

        <!-- ═══ ORDER FORM (from order_form/mod.rs) ═══ -->
        <div style="display:flex;flex-direction:column;background:#161628;">
          <!-- Widget header -->
          <div class="flex items-center gap-1.5"
               style="height:28px;flex-shrink:0;background:#0f0f1e;border-bottom:1px solid #2a2a3e;padding:0 6px;">
            <div style="width:3px;height:16px;background:#33b358;border-radius:2px;flex-shrink:0;"></div>
            <span style="font-size:12px;color:#c0c0cc;font-family:sans-serif;">Order Form</span>
            <div style="font-size:9px;color:#808090;background:rgba(255,255,255,0.05);padding:1px 4px;border-radius:2px;margin-left:2px;font-family:monospace;">order_form</div>
            <div style="flex:1;"></div>
            <span style="background:rgba(255,255,255,0.04);color:#808090;font-size:10px;padding:1px 5px;border-radius:2px;font-family:monospace;">_</span>
            <span style="background:rgba(255,0,0,0.08);color:#ef5350;font-size:10px;padding:1px 5px;border-radius:2px;margin-left:2px;font-family:monospace;">×</span>
          </div>
          <!-- Form content (matches order_form/mod.rs view() layout, 8px padding, 6px spacing) -->
          <div style="flex:1;overflow:hidden;padding:8px;font-size:11px;font-family:monospace;color:#c0c0cc;">

            <!-- Instrument row: symbol + exchange/market (label_style container) -->
            <div style="display:flex;align-items:center;gap:6px;padding:4px 8px;background:rgba(255,255,255,0.03);border:1px solid #333348;border-radius:3px;margin-bottom:6px;">
              <span style="color:#ffffff;font-weight:600;font-size:12px;">BTC/USDT</span>
              <span style="color:#808090;font-size:10px;">Bybit / Perp</span>
            </div>

            <!-- Order type tabs: Market | Limit | Stop (tab_style, active=Limit) -->
            <div style="display:flex;gap:4px;margin-bottom:6px;">
              {[['Market',false],['Limit',true],['Stop',false]].map(([t,active]) => (
                <div style={`flex:1;text-align:center;padding:3px 0;font-size:10px;border-radius:3px;background:${active?'rgba(51,102,204,0.3)':'rgba(255,255,255,0.04)'};color:${active?'#6688ff':'#808090'};border:${active?'1px solid rgba(77,102,255,0.4)':'1px solid transparent'};`}>
                  {t}
                </div>
              ))}
            </div>

            <!-- Buy / Sell toggle (side_style) -->
            <div style="display:flex;gap:4px;margin-bottom:6px;">
              <div style="flex:1;text-align:center;padding:4px 0;font-size:11px;font-weight:600;border-radius:3px;background:rgba(38,166,154,0.3);color:#26a69a;border:1px solid #26a69a;">Buy</div>
              <div style="flex:1;text-align:center;padding:4px 0;font-size:11px;border-radius:3px;background:rgba(255,255,255,0.04);color:#808090;border:1px solid transparent;">Sell</div>
            </div>

            <!-- Limit Price input -->
            <div style="margin-bottom:6px;">
              <div style="color:#808090;font-size:9px;margin-bottom:2px;">Limit Price</div>
              <div style="padding:4px 8px;background:rgba(255,255,255,0.04);border:1px solid #333348;border-radius:3px;color:#ffffff;font-size:11px;">67,513.00</div>
            </div>

            <!-- Amount input -->
            <div style="margin-bottom:6px;">
              <div style="color:#808090;font-size:9px;margin-bottom:2px;">Amount</div>
              <div style="padding:4px 8px;background:rgba(255,255,255,0.04);border:1px solid #333348;border-radius:3px;color:#ffffff;font-size:11px;">0.100</div>
            </div>

            <!-- Preset buttons: 25% 50% 75% 100% (preset_style) -->
            <div style="display:flex;gap:4px;margin-bottom:6px;">
              {['25%','50%','75%','100%'].map(p => (
                <div style="flex:1;text-align:center;padding:2px 0;font-size:9px;background:rgba(255,255,255,0.06);color:#808090;border-radius:2px;">{p}</div>
              ))}
            </div>

            <!-- SL / TP rows -->
            <div style="display:flex;align-items:center;gap:4px;margin-bottom:4px;">
              <span style="color:#808090;font-size:10px;width:22px;flex-shrink:0;">SL:</span>
              <div style="flex:1;padding:3px 6px;background:rgba(255,255,255,0.04);border:1px solid #333348;border-radius:3px;color:#808090;font-size:10px;">Stop Loss</div>
            </div>
            <div style="display:flex;align-items:center;gap:4px;margin-bottom:6px;">
              <span style="color:#808090;font-size:10px;width:22px;flex-shrink:0;">TP:</span>
              <div style="flex:1;padding:3px 6px;background:rgba(255,255,255,0.04);border:1px solid #333348;border-radius:3px;color:#808090;font-size:10px;">Take Profit</div>
            </div>

            <!-- Available balance -->
            <div style="display:flex;gap:4px;font-size:10px;margin-bottom:4px;">
              <span style="color:#808090;">Available:</span>
              <span style="color:#ffffff;">1,240.50 USDT</span>
            </div>

            <!-- Total -->
            <div style="display:flex;justify-content:space-between;font-size:10px;color:#808090;margin-bottom:6px;">
              <span>Total:</span><span style="color:#c0c0cc;">$6,751.30</span>
            </div>

            <!-- Submit button (submit_style is_buy=true → BID_GREEN 0.8 alpha) -->
            <div style="width:100%;padding:8px 0;text-align:center;font-size:13px;font-weight:700;background:rgba(38,166,154,0.8);color:#ffffff;border-radius:4px;margin-bottom:8px;">
              Buy BTC
            </div>

            <!-- Hotkey hints -->
            <div style="font-size:9px;color:#808090;">
              <div style="margin-bottom:3px;">Quick keys:</div>
              <div style="display:flex;gap:3px;flex-wrap:wrap;">
                {['F1 Buy','F2 Sell','F3 Close↑','F4 Close↓','F5 Cancel'].map(k => (
                  <span style="padding:1px 4px;background:#0f0f1e;border:1px solid #2a2a3e;border-radius:2px;color:#808090;">{k}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div><!-- end pane grid -->

      <!-- ── Trades tape strip (from trades/mod.rs — Time|Price|Amount|Total header + rows) ── -->
      <div style="height:24px;background:#0f0f1e;border-top:1px solid #2a2a3e;display:flex;align-items:center;overflow:hidden;padding:0 8px;">
        <!-- Column headers -->
        <div style="display:flex;gap:0;font-size:9px;font-family:monospace;flex-shrink:0;margin-right:12px;">
          <span style="color:#808090;width:65px;">Time</span>
          <span style="color:#808090;width:80px;">Price</span>
          <span style="color:#808090;width:62px;">Amount</span>
          <span style="color:#808090;width:62px;">Total</span>
        </div>
        <!-- Trade rows -->
        <div style="display:flex;gap:12px;overflow:hidden;mask-image:linear-gradient(to right,transparent,black 3%,black 90%,transparent);">
          {trades.map(t => (
            <span style="display:flex;gap:0;font-size:9px;font-family:monospace;flex-shrink:0;white-space:nowrap;">
              <span style="color:#808090;width:65px;">{t.time}</span>
              <span style={`color:${t.side==='buy'?'#26a69a':'#ef5350'};width:80px;`}>{t.price}</span>
              <span style={`color:${t.side==='buy'?'#26a69a':'#ef5350'};width:62px;`}>{t.amt}</span>
              <span style="color:#808090;">{(parseFloat(t.price.replace(/,/g,'')) * parseFloat(t.amt)).toFixed(0)}</span>
            </span>
          ))}
        </div>
      </div>

    </div><!-- end terminal window -->
  </div>

</section>

<style>
  .terminal-float {
    animation: termFloat 6s ease-in-out infinite;
  }
  @keyframes termFloat {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }
</style>
