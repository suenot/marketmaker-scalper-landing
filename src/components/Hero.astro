<section class="relative min-h-screen flex flex-col items-center justify-center pt-24 pb-20 px-4 overflow-hidden">
  <!-- Dynamic Background -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[#0a0b0f]"></div>
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 50% -20%, #00d4a030, transparent 70%);"></div>
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-accent-green/5 blur-[120px] rounded-full animate-pulse-slow"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 text-center max-w-5xl mx-auto mb-16">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-accent-green/20 bg-accent-green/5 mb-8 animate-fade-in">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-green opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent-green"></span>
      </span>
      <span class="text-xs font-mono font-medium text-accent-green tracking-wide">V0.1.0 • HIGH PERFORMANCE TRADING</span>
    </div>

    <h1 class="text-6xl md:text-8xl font-bold tracking-tighter mb-6 leading-[0.9] text-balance">
      Precision Trading<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-green to-accent-blue">Real-Time Speed</span>
    </h1>

    <p class="text-xl md:text-2xl mb-10 max-w-2xl mx-auto leading-relaxed text-text-secondary">
      Professional crypto scalping terminal built with <span class="text-text-primary font-medium">Rust & Iced</span>.
      Blazing fast execution, advanced cluster charts, and deep liquidity visualization.
    </p>

    <div class="flex flex-col sm:flex-row gap-5 justify-center items-center mb-12">
      <a href="#download"
         class="px-10 py-4 rounded-xl font-bold text-lg transition-all bg-accent-green text-bg-primary hover:shadow-[0_0_20px_rgba(0,212,160,0.4)] hover:scale-105 active:scale-95">
        Get Started Free
      </a>
      <a href="#features"
         class="px-10 py-4 rounded-xl border border-border bg-bg-card/50 backdrop-blur-sm font-medium text-lg transition-all hover:bg-bg-hover hover:border-border-light">
        View Features
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-12 py-4 border-y border-border/50">
      {[
        ['20+','Exchanges'],
        ['<1ms','Latency'],
        ['Rust','Backend'],
        ['0%','Fees']
      ].map(([v,l]) => (
        <div class="flex flex-col items-center">
          <div class="text-4xl font-bold font-mono text-text-primary tracking-tighter whitespace-nowrap">{v}</div>
          <div class="text-xs font-medium text-accent-green/60 uppercase tracking-widest mt-1">{l}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════ TERMINAL MOCKUP ═══════════════════════════ -->
  <div class="relative z-10 w-full max-w-[1200px] mx-auto terminal-float px-2 sm:px-0" aria-hidden="true">
    <!-- Glow behind terminal -->
    <div class="absolute -inset-4 bg-accent-green/10 blur-3xl opacity-50 rounded-[2rem]"></div>

    <div class="relative rounded-2xl overflow-hidden border border-white/10 bg-[#0e0f17] shadow-[0_40px_100px_rgba(0,0,0,0.9)]">

      <!-- ── macOS window chrome ── -->
      <div class="flex items-center justify-between px-4 py-2.5 bg-[#0a0b0f] border-b border-white/5">
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-[#ff5f57] border border-black/10"></div>
          <div class="w-3 h-3 rounded-full bg-[#febc2e] border border-black/10"></div>
          <div class="w-3 h-3 rounded-full bg-[#28c840] border border-black/10"></div>
        </div>
        <div class="absolute left-1/2 -translate-x-1/2 flex items-center gap-2 px-3 py-1 bg-white/5 rounded-md border border-white/5">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none">
            <path d="M2 12L6 6L9 9L12 4L14 6" stroke="#00d4a0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="text-[10px] uppercase tracking-widest text-[#8695a8] font-mono">MarketMaker Scalper • BTCUSDT</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-white/5"></div>
        </div>
      </div>

      <!-- ── Tab bar ── -->
      <div class="flex items-center justify-between px-2 bg-[#0e0f17] border-b border-white/5 h-10">
        <div class="flex items-center gap-1.5 h-full pt-1">
          {['Binance','Bybit','OKX'].map((t, i) => (
            <div class={`flex items-center gap-2 px-3 h-full rounded-t-lg text-[10px] font-mono border-x border-t transition-colors ${i===0 ? 'bg-[#13141e] border-white/10 text-text-primary' : 'bg-transparent border-transparent text-[#8695a8] hover:text-text-primary'}`}>
              <div class={`w-1.5 h-1.5 rounded-full ${i===0 ? 'bg-accent-green' : 'bg-white/10'}`}></div>
              {t}
            </div>
          ))}
          <div class="px-2 text-[#8695a8] hover:text-text-primary cursor-pointer">+</div>
        </div>
        <div class="flex items-center gap-3 pr-2">
          <div class="flex items-center gap-1 px-2 py-1 bg-white/5 rounded border border-white/5 text-[9px] font-mono">
            <span class="text-accent-green tracking-tighter">60.0 FPS</span>
            <span class="text-[#8695a8]">|</span>
            <span class="text-accent-blue tracking-tighter">1.2 MS</span>
          </div>
        </div>
      </div>

      <!-- ── Toolbar ── -->
      <div class="flex items-center gap-4 px-4 h-10 bg-[#13141e] border-b border-white/5 text-[10px] font-mono">
        <div class="flex items-center gap-2">
          <span class="text-accent-green">●</span>
          <span class="text-[#a0aaba]">CONNECTION:</span>
          <span class="text-text-primary font-bold">STABLE</span>
        </div>
        <div class="h-4 w-[1px] bg-white/10"></div>
        <div class="flex items-center gap-2">
           <span class="text-[#a0aaba]">MARKET:</span>
           <span class="px-1.5 py-0.5 bg-accent-green/10 text-accent-green rounded border border-accent-green/20">BTCUSDT</span>
        </div>
        <div class="flex items-center gap-2">
           <span class="text-[#a0aaba]">PRICE:</span>
           <span class="text-accent-green font-bold">72,394.20</span>
        </div>
        <div class="flex-1"></div>
        <div class="flex items-center gap-1">
          {['Cluster','Tick','OB','Tape','Chart'].map((b, i) => (
            <button class={`px-2.5 py-1 rounded transition-all ${i===0 ? 'bg-accent-green text-bg-primary font-bold shadow-[0_0_10px_rgba(0,212,160,0.3)]' : 'text-[#8695a8] hover:bg-white/5'}`}>{b}</button>
          ))}
        </div>
      </div>

      <!-- ── Main Editor Area ── -->
      <div class="grid grid-cols-[1fr_320px] h-[580px] bg-[#0a0b0f]">
        <!-- Left: Workspace -->
        <div class="grid grid-cols-2 grid-rows-2 p-1 gap-1 border-r border-white/5">
          <!-- Widget 1: Clusters -->
          <div class="bg-[#13141e] rounded-lg border border-white/5 overflow-hidden flex flex-col shadow-inner">
            <div class="px-2 py-1 bg-[#0a0b0f] flex items-center justify-between border-b border-white/5">
               <span class="text-[9px] font-mono text-[#8695a8] uppercase tracking-widest">Cluster Chart</span>
               <div class="flex gap-1">
                 <div class="w-1.5 h-1.5 rounded-full bg-white/10"></div>
               </div>
            </div>
            <div class="flex-1 p-2 font-mono text-[9px] overflow-hidden">
               <div class="flex justify-between border-b border-white/5 pb-1 mb-1 text-[#8695a8]">
                 <span>PRICE</span>
                 <span>VOLUME</span>
                 <span>DELTA</span>
               </div>
               {[...Array(15)].map((_, i) => (
                 <div class={`flex justify-between py-0.5 px-1 rounded ${i === 7 ? 'bg-accent-green/20 text-accent-green' : 'text-[#a0aaba]/70'}`}>
                    <span>72,39{9-i}.{i}</span>
                    <span class="text-right">{(Math.random()*10).toFixed(2)}</span>
                    <span class={i % 3 === 0 ? 'text-accent-red font-bold' : 'text-accent-green font-bold'}>{(Math.random()*5 - 2).toFixed(2)}</span>
                 </div>
               ))}
            </div>
          </div>
          <!-- Widget 2: Bubble Chart -->
          <div class="bg-[#13141e] rounded-lg border border-white/5 overflow-hidden flex flex-col bg-grid p-2">
            <div class="flex-1 relative overflow-hidden">
               <svg class="w-full h-full" viewBox="0 0 200 200">
                  <circle cx="50" cy="80" r="15" fill="#00d4a0" fill-opacity="0.3" stroke="#00d4a0" stroke-width="1" />
                  <circle cx="120" cy="40" r="25" fill="#ff4757" fill-opacity="0.3" stroke="#ff4757" stroke-width="1" />
                  <circle cx="150" cy="130" r="10" fill="#00d4a0" fill-opacity="0.5" stroke="#00d4a0" stroke-width="1" />
                  <circle cx="80" cy="150" r="30" fill="#ff4757" fill-opacity="0.2" stroke="#ff4757" stroke-width="1" />
                  <circle cx="100" cy="100" r="5" fill="#ffffff" fill-opacity="0.5" />
               </svg>
            </div>
          </div>
          <!-- Widget 3: Tape -->
          <div class="bg-[#13141e] rounded-lg border border-white/5 overflow-hidden flex flex-col">
             <div class="px-2 py-1 bg-[#0a0b0f] flex items-center justify-between border-b border-white/5 text-[9px] font-mono text-[#8695a8]">TAPE</div>
             <div class="flex-1 p-2 font-mono text-[9px]">
               {[...Array(12)].map((_, i) => (
                 <div class="flex justify-between border-b border-white/5 py-1">
                   <span class={i % 2 === 0 ? 'text-accent-green' : 'text-accent-red'}>{i % 2 === 0 ? 'BUY' : 'SELL'}</span>
                   <span class="text-[#a0aaba]">{(Math.random()*2).toFixed(3)} BTC</span>
                   <span class="text-text-primary">22:04:{(30-i).toString().padStart(2, '0')}</span>
                 </div>
               ))}
             </div>
          </div>
          <!-- Widget 4: Positions -->
          <div class="bg-[#13141e] rounded-lg border border-white/5 overflow-hidden flex flex-col">
            <div class="px-2 py-1 bg-[#0a0b0f] flex items-center justify-between border-b border-white/5 text-[9px] font-mono text-[#8695a8]">POSITIONS</div>
            <div class="flex-1 p-4 flex flex-col items-center justify-center gap-2">
               <span class="text-[10px] text-[#a0aaba]">BTCUSDT LONG</span>
               <span class="text-2xl font-bold font-mono text-accent-green">+ 12.42%</span>
               <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                 <div class="h-full bg-accent-green w-[70%]"></div>
               </div>
            </div>
          </div>
        </div>

        <!-- Right: Order Book -->
        <div class="bg-[#13141e] flex flex-col border-l border-white/5 shadow-2xl">
          <div class="h-8 bg-[#0a0b0f] border-b border-white/5 flex items-center justify-between px-3 text-[9px] font-mono text-[#8695a8]">
            <span>ORDER BOOK</span>
            <span class="text-accent-green">DEPTH: 100</span>
          </div>
          <div class="flex-1 flex flex-col font-mono text-[10px] p-2">
            <!-- Asks -->
            <div class="flex flex-col-reverse gap-[1px]">
              {[...Array(12)].map((_, i) => (
                <div class="relative flex justify-between px-2 py-0.5 group hover:bg-white/5 cursor-pointer">
                  <div class="absolute right-0 top-0 bottom-0 bg-accent-red/10" style={`width: ${Math.random()*80}%`}></div>
                  <span class="text-accent-red z-10 font-bold">72,40{i}.5</span>
                  <span class="text-text-primary z-10">{(Math.random()*4).toFixed(3)}</span>
                </div>
              ))}
            </div>
            <!-- Spread -->
            <div class="my-2 py-1 border-y border-white/10 flex justify-between items-center px-2 bg-white/5 rounded">
               <span class="text-[11px] font-bold text-text-primary italic tracking-widest">72,394.2</span>
               <span class="text-[9px] text-[#8695a8]">SPREAD: 1.5</span>
            </div>
            <!-- Bids -->
            <div class="flex flex-col gap-[1px]">
              {[...Array(15)].map((_, i) => (
                <div class="relative flex justify-between px-2 py-0.5 group hover:bg-white/5 cursor-pointer">
                  <div class="absolute right-0 top-0 bottom-0 bg-accent-green/10" style={`width: ${Math.random()*80}%`}></div>
                  <span class="text-accent-green z-10 font-bold">72,38{9-i}.2</span>
                  <span class="text-text-primary z-10">{(Math.random()*6).toFixed(3)}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- ── Status bar ── -->
      <div class="h-7 bg-[#0a0b0f] border-t border-white/5 flex items-center px-4 gap-6 text-[9px] font-mono">
        <div class="flex items-center gap-2">
           <span class="w-1.5 h-1.5 rounded-full bg-accent-green animate-pulse"></span>
           <span class="text-[#8695a8]">PRODUCER RUNNING</span>
        </div>
        <div class="flex items-center gap-2">
           <span class="text-[#a0aaba]">LATENCY:</span>
           <span class="text-accent-green font-bold">0.42ms</span>
        </div>
        <div class="flex-1"></div>
        <div class="text-[#8695a8]">SYSTEM LOAD: 4%</div>
      </div>

    </div><!-- end terminal -->
  </div>

</section>

<style>
  .terminal-float {
    animation: termFloat 8s ease-in-out infinite;
    perspective: 1000px;
  }
  @keyframes termFloat {
    0%, 100% { transform: translateY(0) rotateX(1deg) rotateY(-0.5deg); }
    50% { transform: translateY(-15px) rotateX(-1deg) rotateY(0.5deg); }
  }

  .bg-grid {
    background-image:
      linear-gradient(rgba(0, 212, 160, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 160, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  /* Smooth reveal for typography */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
</style>

