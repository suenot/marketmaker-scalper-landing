---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'MarketMaker Scalper — Professional Crypto Trading Terminal',
  description = 'A lightning-fast desktop trading terminal for professional crypto traders. Real-time order books, multi-exchange support, advanced charting, and hotkey-driven execution.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0b0f" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://scalper.marketmaker.cc" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-bg-primary text-text-primary font-sans antialiased overflow-x-hidden">
    <slot />
  </body>
</html>
